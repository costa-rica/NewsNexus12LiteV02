{
  "name": "news-nexus-lite-worker-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "cheerio": "1.2.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "playwright": "1.61.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "25.9.3",
    "@types/supertest": "7.2.0",
    "eslint": "10.5.0",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
